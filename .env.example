PRODUCERSCENTER_BACKEND_NAME=ProducersCenter Backend
PRODUCERSCENTER_BACKEND_DEBUG=true
# PostgreSQL is the primary backend database.
# Render/Heroku style postgres:// URLs are accepted and normalized by the app.
PRODUCERSCENTER_BACKEND_DATABASE_URL=postgresql+psycopg://producerscenter:change-me@localhost:5432/producerscenter_backend
# Local fallback:
# PRODUCERSCENTER_BACKEND_DATABASE_URL=sqlite:///./storage/backend.db
PRODUCERSCENTER_BACKEND_API_KEY=
PRODUCERSCENTER_BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8787
PRODUCERSCENTER_BACKEND_PROXY_CHECK_CONCURRENCY=30
PRODUCERSCENTER_BACKEND_STREAM_RESOLVE_CONCURRENCY=1
PRODUCERSCENTER_BACKEND_PROXY_ATTEMPTS=8
PRODUCERSCENTER_BACKEND_STREAM_CACHE_HOURS=6
PRODUCERSCENTER_BACKEND_DIRECT_FIRST=true
